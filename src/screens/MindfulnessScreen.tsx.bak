    backgroundColor: 'rgba(0,0,0,0.4)',
    justifyContent: 'flex-end',
  },
  overlayBg: {
    ...StyleSheet.absoluteFillObject,
  },
  sheet: {
    backgroundColor: MC.card,
    borderTopLeftRadius: 28,
    borderTopRightRadius: 28,
    paddingHorizontal: 20,
    paddingBottom: 36,
    paddingTop: 12,
    maxHeight: '85%',
  },
  sheetHandle: {
    width: 40,
    height: 4,
    borderRadius: 2,
    backgroundColor: MC.border,
    alignSelf: 'center',
    marginBottom: 16,
  },
  sheetHead: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'center',
    marginBottom: 20,
  },
  sheetTitle: {
    fontSize: 20,
    color: MC.text,
    fontFamily: MF.bold,
  },

  /* Stats Grid */
  statsGrid: {
    flexDirection: 'row',
    flexWrap: 'wrap',
    justifyContent: 'space-between',
    gap: 12,
    marginBottom: 20,
  },
  statItem: {
    width: '47%',
    borderRadius: 16,
    padding: 18,
    alignItems: 'center',
    minHeight: 110,
  },
  statNum: {
    fontSize: 30,
    color: MC.text,
    fontFamily: MF.bold,
    marginVertical: 4,
  },
  statLabel: {
    fontSize: 12,
    color: MC.textDim,
    fontFamily: MF.medium,
    textAlign: 'center',
  },
  sheetCloseBtn: {
    backgroundColor: MC.text,
    paddingVertical: 14,
    borderRadius: 14,
    alignItems: 'center',
  },
  sheetCloseBtnText: {
    fontSize: 14,
    color: '#FFF',
    fontFamily: MF.semi,
  },

  /* Mood Selector */
  moodSelTitle: {
    fontSize: 20,
    fontFamily: MF.bold,
    color: MC.text,
    marginBottom: 18,
    textAlign: 'center',
  },
  moodOpts: {
    gap: 10,
  },
  moodOpt: {
    flexDirection: 'row',
    alignItems: 'center',
    padding: 14,
    backgroundColor: MC.surfaceMuted,
    borderRadius: 14,
    gap: 12,
  },
  moodOptSel: {
    backgroundColor: MC.accentSoft,
    borderWidth: 2,
    borderColor: MC.accent,
  },
  moodOptEmoji: {
    fontSize: 28,
  },
  moodOptText: {
    fontSize: 15,
    fontFamily: MF.semi,
    color: MC.text,
    flex: 1,
  },
  moodOptTextSel: {
    color: MC.accent,
  },
  moodConfirmBtn: {
    marginTop: 18,
    padding: 14,
    backgroundColor: MC.accent,
    borderRadius: 14,
    alignItems: 'center',
  },
  moodConfirmText: {
    fontSize: 14,
    color: '#FFF',
    fontFamily: MF.semi,
  },
  moodPrompt: {
    marginTop: 18,
    padding: 14,
    alignItems: 'center',
  },
  moodPromptText: {
