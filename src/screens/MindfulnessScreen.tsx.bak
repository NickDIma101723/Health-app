    duration: 10,
    description: 'Balance your nervous system',
    bg: '#EDE7F6',
    tint: '#7E57C2',
    difficulty: 'Intermediate',
    instructions: [
      'Breathe in for 4 seconds',
      'Hold for 4 seconds',
